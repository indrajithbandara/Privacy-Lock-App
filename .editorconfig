# EditorConfig for Privacy Lock Project
# Web: https://editorconfig.org

root = true

# Global settings
[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

# Kotlin / Java styles
[*.{kt,kts,java}]
indent_size = 4
max_line_length = 120

# Gradle configurations
[*.{gradle,gradle.kts}]
indent_size = 4

# XML layouts and resources
[*.xml]
indent_size = 4

# JSON files
[*.json]
indent_size = 2

# YAML configuration files
[*.{yml,yaml}]
indent_size = 2

# Markdown documentation
[*.md]
indent_size = 2
trim_trailing_whitespace = false
