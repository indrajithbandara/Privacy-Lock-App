<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude local secure SQLite database to prevent plaintext backup exposure -->
        <exclude domain="database" path="privacy_lock_db"/>
        <exclude domain="database" path="privacy_lock_db-shm"/>
        <exclude domain="database" path="privacy_lock_db-wal"/>
    </cloud-backup>
    <device-transfer>
        <!-- Exclude local secure SQLite database to prevent plaintext device-to-device transfers -->
        <exclude domain="database" path="privacy_lock_db"/>
        <exclude domain="database" path="privacy_lock_db-shm"/>
        <exclude domain="database" path="privacy_lock_db-wal"/>
    </device-transfer>
</data-extraction-rules>
